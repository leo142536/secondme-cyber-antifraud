# ============================
# SecondMe OAuth App 凭据
# 在 https://develop.second.me 创建应用后获得
# ============================
SECONDME_CLIENT_ID=your-client-id-here
SECONDME_CLIENT_SECRET=your-client-secret-here
SECONDME_REDIRECT_URI=http://localhost:3000/api/auth/callback

# SecondMe API 端点（一般不需要改）
SECONDME_API_BASE=https://api.mindverse.com/gate/lab
SECONDME_OAUTH_URL=https://go.second.me/oauth/

# ============================
# LLM 配置（兼容 OpenAI 格式）
# 推荐：DeepSeek（cheap & powerful）
# ============================
LLM_API_KEY=your-llm-api-key-here
# 留空则使用 OpenAI 官方接口
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ============================
# 服务器配置
# ============================
PORT=3000
SESSION_SECRET=change-me-to-a-random-string-in-production
